# Puerto donde correra el servidor API.
PORT=5000
# Modo de ejecucion: development (local) o production (servidor).
NODE_ENV=development
# Local: mongodb://127.0.0.1:27017/bemc
# Atlas: mongodb+srv://USER:PASSWORD@cluster.mongodb.net/bemc?retryWrites=true&w=majority
# Conexion de base de datos (MongoDB local o Atlas).
MONGODB_URI=mongodb://127.0.0.1:27017/bemc
# Clave privada para firmar tokens de sesion (JWT).
JWT_SECRET=change-this-to-a-long-random-secret-in-production
# Tiempo de duracion de la sesion (ejemplo: 7d).
JWT_EXPIRES_IN=7d
# URL del frontend permitida para autenticacion y redirecciones.
CLIENT_URL=http://localhost:5173

# Facebook OAuth — https://developers.facebook.com/
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:5000/api/auth/facebook/callback

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
